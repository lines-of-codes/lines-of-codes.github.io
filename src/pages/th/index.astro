---
import Layout from "@/layouts/th/Layout.astro";
import Footer from "@/components/th/Footer.astro";
import NavBar from "@/components/th/NavBar.astro";
import { Image } from "astro:assets";
import litechatImage from "@/imgs/litechat.png";
import storyTailorImage from "@/imgs/StoryTailor_Desktop_Fluent.png";
import winQsmImage from "@/imgs/WinQSM.png";
import githubMark from "@/imgs/github-mark-white.svg";
import globeAlt from "@/imgs/heroicons-globe-alt.svg";
import "@/styles/index.css";
---

<Layout>
	<NavBar />
	<header>
		<h1 class="text-6xl md:text-7xl font-bold mb-2">ศตคุณ อุตมะ</h1>
		<p>นักเรียนที่กำลังมองหาสิ่งใหม่ ๆ และตามหาประสบการณ์</p>
	</header>
	<main class="text-center">
		<section
			id="aboutme"
			class="bg-gradient-to-tr from-slate-900 to-slate-700 text-slate-50 flex justify-center"
		>
			<div class="max-w-1/2 print:max-w-full">
				<h2 class="mb-2 leading-normal" id="aboutMeHeader">
					เกี่ยวกับตัวฉัน
				</h2>
				<p class="md:text-base text-lg">
					ปัจจุบันเป็นนักเรียนที่ศึกษาอยู่ที่วิทยาลัยเทคนิคหนองคาย
					ดิฉันเป็นคนชอบลองอะไรใหม่ ๆ และกำลังตามหาประสบการณ์ในหลาย ๆ
					ด้านเช่น กราฟิกดีไซน์ การพัฒนาเกม และการพัฒนาเว็บไซต์
				</p>
			</div>
		</section>
		<section id="projects">
			<h2 class="pb-2 mb-2">โปรเจกต์</h2>
			<div id="projectList">
				<div class="card" id="litechat">
					<div class="card-image">
						<Image
							src={litechatImage}
							alt="A screenshot of litechat's interface."
						/>
					</div>
					<div class="card-content">
						<h3>litechat</h3>
						<p>แอพลิเคชั่นแชทที่รวดเร็วและปลอดภัย</p>
					</div>
					<div class="tags">
						<span class="tag">Web</span>
						<span class="tag">PocketBase</span>
						<span class="tag">Mithril.js</span>
					</div>
					<div class="card-links">
						<a
							href="https://github.com/lines-of-codes/litechat"
							target="_blank"
							rel="noopener noreferrer"
						>
							<Image
								src={githubMark}
								alt="GitHub"
								width="32"
								height="32"
							/>
						</a>
						<a
							href="https://litechat.taeyai.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							<Image
								src={globeAlt}
								alt="Web"
								width="32"
								height="32"
							/>
						</a>
					</div>
				</div>
				<div class="card">
					<div class="card-image">
						<Image
							src={storyTailorImage}
							alt="A screenshot of StoryTailor's interface."
						/>
					</div>
					<div class="card-content">
						<h3>StoryTailor</h3>
						<p>
							StoryTailor เป็นแอพลิเคชั่นครอสแพลทฟอร์ม
							สำหรับการเขียนเรื่องราววิชวลโนเวล
							ให้คุณสามารถเขียนเรื่องราวที่ใดก็ได้
						</p>
					</div>
					<div class="tags">
						<span class="tag">Flutter</span>
						<span class="tag">Android</span>
						<span class="tag">PocketBase</span>
					</div>
					<div class="card-links">
						<a
							href="https://github.com/lines-of-codes/litechat"
							target="_blank"
							rel="noopener noreferrer"
						>
							<Image
								src={githubMark}
								alt="GitHub"
								width="32"
								height="32"
							/>
						</a>
					</div>
				</div>
				<div class="card">
					<div class="card-image">
						<Image
							src={winQsmImage}
							alt="A screenshot of WinQSM's interface."
						/>
					</div>
					<div class="card-content">
						<h3>QSMSharp</h3>
						<p>ซอฟท์แวร์จัดการเซิร์ฟเวอร์ไมน์คราฟท์</p>
					</div>
					<div class="tags">
						<span class="tag">C#</span>
						<span class="tag">WinUI</span>
					</div>
					<div class="card-links">
						<a
							href="https://github.com/lines-of-codes/QSMSharp"
							target="_blank"
							rel="noreferrer noopener"
						>
							<Image
								src={githubMark}
								alt="GitHub"
								width="32"
								height="32"
							/>
						</a>
					</div>
				</div>
			</div>
		</section>
		<section
			id="contact"
			class="bg-gradient-to-bl from-slate-700 to-slate-900 text-slate-50"
		>
			<h2 class="mb-4">ติดต่อ</h2>
			<div class="grid grid-cols-[1fr_2fr] gap-x-4">
				<div class="font-bold text-right">Email</div>
				<div class="text-left">
					linesofcodes[at]dailitation[dot]xyz <a
						href="https://keys.openpgp.org/vks/v1/by-fingerprint/8A487B532BEF7B324339AC1CFBE9E5E346F3DDE8"
						class="underline"
					>
						(มีคีย์ PGP/GPG)
					</a>
				</div>
				<div class="font-bold text-right">Discord</div>
				<div class="text-left">gamecreator</div>
				<div class="font-bold text-right">Instagram</div>
				<div class="text-left">satakun.utama</div>
				<div class="font-bold text-right">Bluesky</div>
				<div class="text-left">@linesofcodes.bsky.social</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
